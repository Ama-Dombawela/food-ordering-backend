spring.application.name=food-ordering-backend

spring.datasource.url=jdbc:mysql://localhost:3306/foodOrder_db
spring.datasource.username=root
# Replace with your actual MySQL password
spring.datasource.password=yourpassword

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.open-in-view=false
spring.jpa.defer-datasource-initialization=true

# change to 'never' after first run
spring.sql.init.mode=always

server.port=8080

# Replace with a strong, random secret key
app.jwt.secret=your_jwt_secret_here
app.jwt.expiration=86400000